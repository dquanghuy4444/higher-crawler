# Server
PORT=3000

# Python runner. Leave empty to use the project virtualenv or system python.
# PYTHON_BIN=/absolute/path/to/python

# Gemini API key for PDF product attribute extraction.
# Keep the real value only in .env, never commit it.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_API_ENDPOINT=https://generativelanguage.googleapis.com/v1beta
AI_ATTRIBUTES_MAX_INPUT_CHARS=16000

# Optional alias used by ai-attribute-service.js.
# AI_ATTRIBUTES_API_KEY=
# AI_ATTRIBUTES_MODEL=gemini-2.5-flash
